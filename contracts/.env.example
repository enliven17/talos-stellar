# ─── Stellar Testnet Account ───────────────────────────────
# Create at https://lab.stellar.org or https://friendbot.stellar.org
# Account ID format: GAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Secret key: SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Protocol Wallet ──────────────────────────────────────
# Receives 3% launchpad fee on every Talos Genesis.
# Stellar format (G...). Defaults to deployer address if not set.

TALOS_PROTOCOL_WALLET=GAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Post-Deployment (auto-generated) ─────────────────────
# These are printed after Soroban contract deployment.
# Copy them to apps/web/.env as well.

# NEXT_PUBLIC_TALOS_REGISTRY_CONTRACT=C...
# NEXT_PUBLIC_TALOS_NAME_SERVICE_CONTRACT=C...

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...

# ─── Stellar (Server-side — contract deployment, asset operations) ──
STELLAR_ACCOUNT_ID=GAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STELLAR_NETWORK=testnet

# ─── Smart Contracts (Stellar Testnet — Soroban contract IDs) ──
# Deploy with: soroban contract deploy (see contracts/README.md)
NEXT_PUBLIC_TALOS_REGISTRY_CONTRACT=C...
NEXT_PUBLIC_TALOS_NAME_SERVICE_CONTRACT=C...

# ─── Wallet Connection (Stellar) ─────────────────────────
# Using @creit-tech/stellar-wallets-kit for Albedo, xbull, freighter, etc.
NEXT_PUBLIC_STELLAR_WALLET_NETWORK=testnet

# ─── x402 on Stellar ─────────────────────────────────────
# Stellar x402 facilitator + OpenZeppelin settlement
X402_FACILITATOR_URL=https://facilitator.x402.org
X402_API_KEY=x402_...
X402_SETTLEMENT_NETWORK=stellar-testnet

# ─── Stellar Operator (Server-side signing for agent operations) ──
# Used by /api/talos/:id/sign and /api/talos/:id/transfer
# One operator key handles all server-side Stellar operations
STELLAR_OPERATOR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Talos Agent Secrets (per-agent, stored as TALOS_AGENT_SECRET_{id}) ──
# Each Talos has its Stellar secret key stored server-side for autonomous signing
# These are created automatically during Talos genesis and stored in env/DB

# ─── Stellar RPC ─────────────────────────────────────────
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# ─── AI Services (fulfillment handlers) ──────────────────
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# ─── Talos Genesis ──────────────────────────────────────
NEXT_PUBLIC_TALOS_CREATION_XLM=20

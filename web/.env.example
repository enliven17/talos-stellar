# ─── Database (Supabase) ──────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database
# Use "Transaction" pooler URL for DATABASE_URL (port 6543)
# Use "Direct" connection URL for DIRECT_URL (port 5432)
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.XXXX:PASSWORD@db.XXXX.supabase.co:5432/postgres

# ─── Stellar Network ──────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# NEXT_PUBLIC_ variants required for client-side code (soroban.ts / launch page)
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# ─── Stellar Operator (Server-side signing) ──────────────
# Generates: stellar keys generate operator --network testnet
# View secret: stellar keys show operator
STELLAR_OPERATOR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Soroban Smart Contracts ─────────────────────────────
# Run: cd contracts && ./deploy.sh testnet (returns contract IDs)
NEXT_PUBLIC_TALOS_REGISTRY_CONTRACT=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_TALOS_NAME_SERVICE_CONTRACT=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Wallet Connection (Stellar) ─────────────────────────
NEXT_PUBLIC_STELLAR_WALLET_NETWORK=testnet

# ─── x402 on Stellar ─────────────────────────────────────
X402_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
X402_API_KEY=
X402_SETTLEMENT_NETWORK=stellar-testnet

# ─── AI Services ──────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
TAVILY_API_KEY=tvly-...

# ─── Talos Genesis ────────────────────────────────────────
NEXT_PUBLIC_TALOS_CREATION_XLM=20
